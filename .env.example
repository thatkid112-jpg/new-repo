# Optional: absolute site URL for SEO metadata, canonicals, sitemap, and OG tags.
# Leave blank in prod — it falls back to Vercel's production domain automatically.
# Set this to your custom domain once you connect one (e.g. https://trendsite.com).
NEXT_PUBLIC_SITE_URL=

# Which data source to pull trends from: "mock" (default, no key needed) or "apify"
TRENDS_PROVIDER=mock

# Postgres (Neon) — used for local dev AND production.
# DATABASE_URL = Neon POOLED connection string (app runtime). Include ?sslmode=require.
# DIRECT_URL   = Neon DIRECT connection string (Prisma Migrate only).
DATABASE_URL=
DIRECT_URL=

# Shared secret required to call /api/ingest (set to any random string).
# On Vercel, also set CRON_SECRET to the SAME value so the platform cron is authorized.
INGEST_SECRET=change-me
CRON_SECRET=change-me

# Only needed when TRENDS_PROVIDER=apify.
# APIFY_TASK_ID is your saved scraper task (e.g. "username~trends24-us"), found on the
# task's API tab in Apify. The app reads that task's latest successful run.
APIFY_TOKEN=
APIFY_TASK_ID=
# APIFY_TRENDS_ACTOR is unused in read-mode (kept for reference / a future trigger-mode).
APIFY_TRENDS_ACTOR=

# Optional "why is this trending?" LLM feature. Leave the selected provider's key blank
# to disable (the app runs fine without it).
#
# Which LLM provider to use: "anthropic" or "openrouter".
EXPLAIN_PROVIDER=anthropic

# --- anthropic provider --- (https://console.anthropic.com)
# Always web-grounded via Anthropic's web_search tool (billed per search).
ANTHROPIC_API_KEY=
EXPLAIN_MODEL=claude-haiku-4-5

# --- openrouter provider --- (https://openrouter.ai/keys)
# OpenAI-compatible gateway to many models. OPENROUTER_MODEL is any OpenRouter slug.
OPENROUTER_API_KEY=
# Any current OpenRouter slug. perplexity/sonar grounds natively (cheap + accurate for
# "why trending now") and is auto-treated as web-grounded — leave OPENROUTER_WEB_SEARCH=false
# for it. For non-grounding models (e.g. deepseek/*, openai/*), set OPENROUTER_WEB_SEARCH=true
# to append ":online" (uses OpenRouter's web plugin, billed per search).
OPENROUTER_MODEL=perplexity/sonar
OPENROUTER_WEB_SEARCH=false

# --- Auth (Auth.js / NextAuth v5) — required for the archive paywall ----------
# AUTH_SECRET signs sessions. Generate with: openssl rand -base64 32
AUTH_SECRET=
# Base URL for auth callbacks. http://localhost:3000 in dev; your domain in prod.
AUTH_URL=http://localhost:3000
# Optional Google OAuth. The "Continue with Google" button only appears when BOTH
# are set; email+password works without them.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe (archive subscription) — use TEST keys to build/verify locally -----
# Create a recurring Price (test mode) in the Stripe dashboard → put its id in
# STRIPE_PRICE_ID. Get STRIPE_WEBHOOK_SECRET from `stripe listen` (CLI) locally,
# or from the webhook endpoint settings in the Stripe dashboard for production.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
