// TrendSite data model. Postgres (Neon) for both local dev and production.
// DATABASE_URL = Neon POOLED connection (used by the app at runtime).
// DIRECT_URL   = Neon DIRECT connection (used by Prisma Migrate only).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Location {
  id        Int        @id @default(autoincrement())
  slug      String     @unique // e.g. "united-states"
  name      String // e.g. "United States"
  woeid     Int? // Yahoo "Where On Earth ID", used by most trend providers
  snapshots Snapshot[]
}

// One row per hourly pull for a location. History is never deleted — it is the product.
model Snapshot {
  id         Int      @id @default(autoincrement())
  locationId Int
  capturedAt DateTime
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  trends     Trend[]

  @@unique([locationId, capturedAt])
  @@index([locationId, capturedAt])
}

model Trend {
  id          Int      @id @default(autoincrement())
  snapshotId  Int
  rank        Int
  name        String
  url         String
  tweetVolume Int?
  snapshot    Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([snapshotId])
}

// LLM-generated "why is this trending?" guess, cached per location + trend name so
// we only pay for one generation per distinct topic (not once per snapshot).
model Explanation {
  id          Int      @id @default(autoincrement())
  locationId  Int
  name        String
  text        String
  model       String
  generatedAt DateTime @default(now())

  @@unique([locationId, name])
  @@index([locationId, name])
}

// --- Auth + billing (archive paywall) ---------------------------------------
// Standard Auth.js (NextAuth v5) Prisma-adapter models, extended with a password
// hash (for the Credentials provider), a Stripe customer id, and a 1:1 Subscription.

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // set for email+password sign-ups; null for OAuth-only users
  stripeCustomerId String? @unique
  createdAt     DateTime  @default(now())

  accounts     Account[]
  sessions     Session[]
  subscription Subscription?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// One subscription per user. The Stripe webhook is the source of truth for `status`
// and `currentPeriodEnd`; archive access is granted only while this row is active.
model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeSubscriptionId String   @unique
  status               String // active | trialing | past_due | canceled | incomplete
  priceId              String
  currentPeriodEnd     DateTime
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
